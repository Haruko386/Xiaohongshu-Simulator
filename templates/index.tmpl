<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>小红书 - 你的生活指南</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link href="/static/index.css" rel="stylesheet">
</head>
<body>

<aside class="sidebar">
    <div class="logo">小红书</div>
    <nav>
        <a href="#" class="nav-item active"><i class="fas fa-compass"></i> 发现</a>
        <a href="#" class="nav-item" onclick="openPublishModal()"><i class="fas fa-plus-square"></i> 发布</a>
        <a href="#" class="nav-item"><i class="fas fa-bell"></i> 通知</a>
        <a href="/user/profile/{{.LoggedInUserID}}" class="nav-item" onclick="checkLogin(event, '{{.LoggedInUserID}}')"><i
                    class="fas fa-user"></i> 我</a>
    </nav>
</aside>

<main class="main-content">
    <header class="header">
        <div class="search-bar">
            <i class="fas fa-search"></i>
            <input type="text" placeholder="搜索小红书">
        </div>
    </header>

    <nav class="categories">
        <div class="cat-item active">推荐</div>
        <div class="cat-item">穿搭</div>
        <div class="cat-item">美食</div>
        <div class="cat-item">彩妆</div>
        <div class="cat-item">影视</div>
        <div class="cat-item">职场</div>
        <div class="cat-item">家居</div>
        <div class="cat-item">游戏</div>
        <div class="cat-item">旅行</div>
        <div class="cat-item">健身</div>
    </nav>

    <div class="waterfall-container">
        {{ range .Posts }}
            <div class="card">

                <img src="/asset/{{ .User.Username }}/Posts/{{ .ID }}/{{ .CoverImage }}" alt="{{ .Title }}"
                     class="card-img">

                <div class="card-info">
                    <div class="card-title">{{ .Title }}</div>
                    <div class="card-meta">
                        <div class="user-info">
                            <img style="max-width: 20px; max-height: 20px; border-radius: 50%" src="/asset/{{ .User.Username }}/{{ .User.Avatar }}">
                        </div>
                        <div class="user-info">
                            <span style="display: flex; align-items: flex-start;">{{ .User.Username }}</span>
                        </div>
                        <div class="likes">
                            <i class="far fa-heart"></i>
                            <span>0</span>
                        </div>
                    </div>
                </div>
            </div>
        {{ end }}
    </div>
</main>

<div id="login-modal" class="modal-overlay" {{ if .NeedsLogin }}style="display: flex;"
     {{ else }}style="display: none;"{{ end }}>
    <div class="modal-content">
        <span class="close-btn" onclick="closeModal()"><i class="fas fa-times"></i></span>

        <div class="modal-left">
            <h3>登录后推荐更懂你的笔记</h3>
            <div class="qr-placeholder">
                <i class="fas fa-qrcode" style="font-size: 80px; color: #ccc;"></i>
            </div>
            <p>可用 <span style="color: var(--primary-red); font-weight: bold;">小红书</span> App 扫码</p>
        </div>

        <div class="modal-right">
            <div class="modal-tabs">
                <span class="modal-tab active" onclick="switchTab('login')">账号登录</span>
                <span class="modal-tab" onclick="switchTab('register')">新用户注册</span>
            </div>

            <div id="login-form">
                <div class="input-group">
                    <input type="text" id="login-username" placeholder="输入用户名">
                </div>
                <div class="input-group">
                    <input type="password" id="login-password" placeholder="输入密码">
                </div>
                <button class="submit-btn" onclick="handleLogin()">登录</button>
            </div>

            <div id="register-form" style="display: none;">
                <div class="input-group">
                    <input type="text" id="reg-username" placeholder="设置用户名">
                </div>
                <div class="input-group">
                    <input type="password" id="reg-password" placeholder="设置密码">
                </div>
                <button class="submit-btn" onclick="handleRegister()">注册</button>
            </div>

            <div id="msg-box" class="message"></div>
        </div>
    </div>
</div>

<div id="publish-modal" class="modal-overlay" style="display: none;">
    <div class="edit-modal-content" style="width: 500px;"><span class="close-btn" onclick="closePublishModal()"><i
                    class="fas fa-times"></i></span>
        <h3 style="text-align: center; margin-bottom: 20px;">发布新笔记</h3>

        <div style="margin-bottom: 15px; text-align: center;">
            <label for="post-cover"
                   style="display: block; cursor: pointer; border: 2px dashed #ccc; padding: 30px; border-radius: 8px;">
                <img id="post-cover-preview" src=""
                     style="max-width: 100%; max-height: 200px; display: none; margin: 0 auto;">
                <span id="post-cover-text"><i class="fas fa-camera"></i> 点击上传封面（必选）</span>
            </label>
            <input type="file" id="post-cover" accept="image/*" style="display: none;"
                   onchange="previewPostCover(event)">
        </div>

        <div class="input-group" style="margin-bottom: 15px;">
            <input type="text" id="post-title" placeholder="填写标题"
                   style="width: 100%; padding: 12px; border: 1px solid #eee; border-radius: 8px;">
        </div>

        <div class="input-group" style="margin-bottom: 15px;">
            <textarea id="post-text" placeholder="在这里写入 Markdown 格式的正文..." rows="6"
                      style="width: 100%; padding: 12px; border: 1px solid #eee; border-radius: 8px; resize: none;"></textarea>
        </div>

        <button class="submit-btn" onclick="submitPost()">立即发布</button>
    </div>
</div>

<script>
    function openPublishModal() { document.getElementById('publish-modal').style.display = 'flex'; }
    function closePublishModal() { document.getElementById('publish-modal').style.display = 'none'; }

    function previewPostCover(event) {
        const file = event.target.files[0];
        if (file) {
            document.getElementById('post-cover-preview').src = URL.createObjectURL(file);
            document.getElementById('post-cover-preview').style.display = 'block';
            document.getElementById('post-cover-text').style.display = 'none';
        }
    }

    async function submitPost() {
        const coverFile = document.getElementById('post-cover').files[0];
        const title = document.getElementById('post-title').value;
        const text = document.getElementById('post-text').value;

        if (!coverFile) return alert("必须上传封面图！");
        if (!title) return alert("请填写标题！");

        const formData = new FormData();
        formData.append("cover", coverFile);
        formData.append("title", title);
        formData.append("text", text);

        try {
            const res = await fetch('/api/post/create', { method: 'POST', body: formData });
            if (res.ok) {
                window.location.reload(); // 发布成功，刷新看首页瀑布流！
            } else {
                const data = await res.json();
                alert(data.error || "发布失败");
            }
        } catch (err) {
            alert("网络错误");
        }
    }

    function closeModal() {
        document.getElementById('login-modal').style.display = 'none';
    }

    // 切换登录/注册 Tab
    function switchTab(type) {
        document.querySelectorAll('.modal-tab').forEach(t => t.classList.remove('active'));
        if (type === 'login') {
            document.querySelectorAll('.modal-tab')[0].classList.add('active');
            document.getElementById('login-form').style.display = 'block';
            document.getElementById('register-form').style.display = 'none';
        } else {
            document.querySelectorAll('.modal-tab')[1].classList.add('active');
            document.getElementById('login-form').style.display = 'none';
            document.getElementById('register-form').style.display = 'block';
        }
        document.getElementById('msg-box').style.display = 'none';
    }

    function showMsg(msg) {
        const box = document.getElementById('msg-box');
        box.innerText = msg;
        box.style.display = 'block';
    }

    // 处理注册
    async function handleRegister() {
        const username = document.getElementById('reg-username').value;
        const password = document.getElementById('reg-password').value;
        if (!username || !password) return showMsg("用户名或密码不能为空");

        const res = await fetch('/api/register', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({username, password})
        });
        const data = await res.json();
        if (res.ok) {
            alert("注册成功，请直接登录！");
            switchTab('login'); // 自动切回登录页面
        } else {
            showMsg(data.error || "注册失败");
        }
    }

    // 处理登录
    async function handleLogin() {
        const username = document.getElementById('login-username').value;
        const password = document.getElementById('login-password').value;
        if (!username || !password) return showMsg("用户名或密码不能为空");

        const res = await fetch('/api/login', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({username, password})
        });
        const data = await res.json();
        if (res.ok) {
            // 登录成功，刷新当前页面，因为有了 Cookie，后端不会再传 NeedsLogin=true
            window.location.reload();
        } else {
            showMsg(data.error || "登录失败");
        }
    }

    function checkLogin(e, uid) {
        if (!uid) {
            e.preventDefault();
            document.getElementById('login-modal').style.display = 'flex';
        }
    }
</script>

</body>
</html>