<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>小红书 - 你的生活指南</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link href="/static/index.css" rel="stylesheet">
</head>
<body>

<aside class="sidebar">
    <div class="logo">小红书</div>
    <nav>
        <a href="#" class="nav-item active"><i class="fas fa-compass"></i> 发现</a>
        <a href="/publish" class="nav-item"><i class="fas fa-plus-square"></i> 发布</a>
        <a href="#" class="nav-item"><i class="fas fa-bell"></i> 通知</a>
        <a href="/user/profile/{{.LoggedInUserID}}" class="nav-item" onclick="checkLogin(event, '{{.LoggedInUserID}}')"><i
                    class="fas fa-user"></i> 我</a>
    </nav>
    <div class="more-container">
        <div class="more-menu" id="more-menu">
            <div class="menu-item">关于小红书</div>
            <div class="menu-item">帮助与客服</div>
            <div class="menu-divider"></div>
            <div class="menu-item" onclick="handleLogout()">退出登录</div>
        </div>
        <div class="more-btn" onclick="toggleMoreMenu(event)">
            <i class="fas fa-bars"></i> 更多
        </div>
    </div>
</aside>

<main class="main-content">
    <header class="header">
        <div class="search-bar">
            <i class="fas fa-search"></i>
            <input type="text" placeholder="搜索小红书">
        </div>
    </header>

    <div class="waterfall-container">
        {{ range .Posts }}
            <div class="card" onclick="openPostDetail('{{ .ID }}')">

                <img src="/asset/{{ .User.Username }}/Posts/{{ .ID }}/{{ .CoverImage }}" alt="{{ .Title }}"
                     class="card-img">

                <div class="card-info">
                    <div class="card-title">{{ .Title }}</div>
                    <div class="card-meta">
                        <div class="user-info">
                            <img style="max-width: 20px; max-height: 20px; border-radius: 50%"
                                 src="/asset/{{ .User.Username }}/{{ .User.Avatar }}">
                        </div>
                        <div class="user-info">
                            <span style="display: flex; align-items: flex-start;">{{ .User.Username }}</span>
                        </div>
                        <div class="likes">
                            <i class="far fa-heart"></i>
                            <span>0</span>
                        </div>
                    </div>
                </div>
            </div>
        {{ end }}
    </div>
</main>

<div id="login-modal" class="modal-overlay" {{ if .NeedsLogin }}style="display: flex;"
     {{ else }}style="display: none;"{{ end }}>
    <div class="modal-content">
        <span class="close-btn" onclick="closeModal()"><i class="fas fa-times"></i></span>

        <div class="modal-left">
            <h3>登录后推荐更懂你的笔记</h3>
            <div class="qr-placeholder">
                <i class="fas fa-qrcode" style="font-size: 80px; color: #ccc;"></i>
            </div>
            <p>可用 <span style="color: var(--primary-red); font-weight: bold;">小红书</span> App 扫码</p>
        </div>

        <div class="modal-right">
            <div class="modal-tabs">
                <span class="modal-tab active" onclick="switchTab('login')">账号登录</span>
                <span class="modal-tab" onclick="switchTab('register')">新用户注册</span>
            </div>

            <div id="login-form">
                <div class="input-group">
                    <input type="text" id="login-username" placeholder="输入用户名">
                </div>
                <div class="input-group">
                    <input type="password" id="login-password" placeholder="输入密码">
                </div>
                <button class="submit-btn" onclick="handleLogin()">登录</button>
            </div>

            <div id="register-form" style="display: none;">
                <div class="input-group">
                    <input type="text" id="reg-username" placeholder="设置用户名">
                </div>
                <div class="input-group">
                    <input type="password" id="reg-password" placeholder="设置密码">
                </div>
                <button class="submit-btn" onclick="handleRegister()">注册</button>
            </div>

            <div id="msg-box" class="message"></div>
        </div>
    </div>
</div>

<div id="post-detail-modal" class="post-detail-overlay" style="display: none;">
    <div class="post-detail-box">
        <div class="post-detail-left">
            <div class="close-detail-btn" onclick="closePostDetail()"><i class="fas fa-times"></i></div>
            <img id="detail-image" src="" alt="笔记封面">
        </div>

        <div class="post-detail-right">
            <div class="detail-header">
                <div class="detail-author">
                    <img id="detail-avatar" src="" onerror="this.onerror=null; this.src='https://via.placeholder.com/40'">
                    <span id="detail-username">加载中...</span>
                </div>
                <button class="btn-follow">关注</button>
            </div>

            <div class="detail-scroll">
                <div id="detail-title" class="detail-title">加载中...</div>
                <div id="detail-text" class="detail-text">加载中...</div>
                <div id="detail-time" class="detail-time">发布时间</div>

                <hr style="border: 0; border-top: 1px solid #f0f0f0; margin: 20px 0;">

                <div id="comment-count-label" class="comment-count">共 0 条评论</div>
                <div id="detail-comments-list" style="padding-bottom: 20px;"></div>
            </div>

            <div class="detail-footer">
                <div style="flex: 1; display: flex; align-items: center; background: #f5f5f5; border-radius: 24px; padding-right: 15px;">
                    <input type="text" id="comment-input" class="comment-input" placeholder="说点什么..." style="flex: 1; background: transparent; padding-right: 5px;">
                    <span onclick="submitComment()" style="color: var(--primary-red); font-weight: bold; cursor: pointer; white-space: nowrap; font-size: 14px;">发送</span>
                </div>
                <div class="interaction-icons" style="margin-left: 15px;">
                    <div class="action-btn" id="btn-like" onclick="toggleLike()">
                        <i id="icon-like" class="far fa-heart"></i>
                        <span id="count-like">0</span>
                    </div>
                    <div class="action-btn" id="btn-collect" onclick="toggleCollect()">
                        <i id="icon-collect" class="far fa-star"></i>
                        <span id="count-collect">0</span>
                    </div>
                    <div class="action-btn">
                        <i class="fas fa-share"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    let currentPostId = null

    function previewPostCover(event) {
        const file = event.target.files[0];
        if (file) {
            document.getElementById('post-cover-preview').src = URL.createObjectURL(file);
            document.getElementById('post-cover-preview').style.display = 'block';
            document.getElementById('post-cover-text').style.display = 'none';
        }
    }

    async function submitPost() {
        const coverFile = document.getElementById('post-cover').files[0];
        const title = document.getElementById('post-title').value;
        const text = document.getElementById('post-text').value;

        if (!coverFile) return alert("必须上传封面图！");
        if (!title) return alert("请填写标题！");

        const formData = new FormData();
        formData.append("cover", coverFile);
        formData.append("title", title);
        formData.append("text", text);

        try {
            const res = await fetch('/api/post/create', {method: 'POST', body: formData});
            if (res.ok) {
                window.location.reload(); // 发布成功，刷新看首页瀑布流！
            } else {
                const data = await res.json();
                alert(data.error || "发布失败");
            }
        } catch (err) {
            alert("网络错误");
        }
    }

    // 切换登录/注册 Tab
    function switchTab(type) {
        document.querySelectorAll('.modal-tab').forEach(t => t.classList.remove('active'));
        if (type === 'login') {
            document.querySelectorAll('.modal-tab')[0].classList.add('active');
            document.getElementById('login-form').style.display = 'block';
            document.getElementById('register-form').style.display = 'none';
        } else {
            document.querySelectorAll('.modal-tab')[1].classList.add('active');
            document.getElementById('login-form').style.display = 'none';
            document.getElementById('register-form').style.display = 'block';
        }
        document.getElementById('msg-box').style.display = 'none';
    }

    function showMsg(msg) {
        const box = document.getElementById('msg-box');
        box.innerText = msg;
        box.style.display = 'block';
    }

    // 处理注册
    async function handleRegister() {
        const username = document.getElementById('reg-username').value;
        const password = document.getElementById('reg-password').value;
        if (!username || !password) return showMsg("用户名或密码不能为空");

        const res = await fetch('/api/register', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({username, password})
        });
        const data = await res.json();
        if (res.ok) {
            alert("注册成功，请直接登录！");
            switchTab('login'); // 自动切回登录页面
        } else {
            showMsg(data.error || "注册失败");
        }
    }

    // 处理登录
    async function handleLogin() {
        const username = document.getElementById('login-username').value;
        const password = document.getElementById('login-password').value;
        if (!username || !password) return showMsg("用户名或密码不能为空");

        const res = await fetch('/api/login', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({username, password})
        });
        const data = await res.json();
        if (res.ok) {
            // 登录成功，刷新当前页面，因为有了 Cookie，后端不会再传 NeedsLogin=true
            window.location.reload();
        } else {
            showMsg(data.error || "登录失败");
        }
    }

    function checkLogin(e, uid) {
        if (!uid) {
            e.preventDefault();
            document.getElementById('login-modal').style.display = 'flex';
        }
    }

    function toggleMoreMenu(e) {
        e.stopPropagation(); // 阻止点击事件冒泡，防止触发下面的全局关闭
        document.getElementById('more-menu').classList.toggle('show');
    }

    // 监听全局点击事件，点击空白处自动关闭菜单
    document.addEventListener('click', function (e) {
        const menu = document.getElementById('more-menu');
        if (menu && menu.classList.contains('show')) {
            menu.classList.remove('show');
        }
    });

    // 处理退出登录
    async function handleLogout() {
        try {
            const res = await fetch('/api/logout', {method: 'POST'});
            if (res.ok) {
                // 登出成功后，强制跳转回首页，首页检测不到 Cookie 会自动弹出登录框
                window.location.href = "/";
            } else {
                alert("退出失败，请重试");
            }
        } catch (err) {
            alert("网络请求错误");
        }
    }

    async function openPostDetail(postId) {
        document.getElementById('post-detail-modal').style.display = 'flex';

        try {
            const res = await fetch(`/api/post/detail?id=${postId}`);
            if (res.ok) {
                const data = await res.json(); // 解析返回的JSON
                currentPostId = postId

                document.getElementById('detail-image').src = `/asset/${data.user.username}/Posts/${data.post.ID}/${data.post.cover_image}`;
                document.getElementById('detail-avatar').src = `/asset/${data.user.username}/${data.user.avatar}`;
                document.getElementById('detail-username').innerText = data.user.username;
                document.getElementById('detail-title').innerText = data.post.title;
                document.getElementById('detail-text').innerText = data.post.text;
                document.getElementById('count-like').innerText = data.like_count || 0;
                document.getElementById('count-collect').innerText = data.collect_count || 0;

                const btnLike = document.getElementById('btn-like');
                const iconLike = document.getElementById('icon-like');
                if (data.is_liked) {
                    btnLike.classList.add('liked');
                    iconLike.className = 'fas fa-heart';
                } else {
                    btnLike.classList.remove('liked');
                    iconLike.className = 'far fa-heart';
                }

                // 根据是否已收藏，切换 class
                const btnCollect = document.getElementById('btn-collect');
                const iconCollect = document.getElementById('icon-collect');
                if (data.is_collected) {
                    btnCollect.classList.add('collected');
                    iconCollect.className = 'fas fa-star';
                } else {
                    btnCollect.classList.remove('collected');
                    iconCollect.className = 'far fa-star';
                }

                // 格式化时间 (截取 YYYY-MM-DD)
                const dateStr = data.post.public_date ? data.post.public_date.split('T')[0] : "未知时间";
                document.getElementById('detail-time').innerText = dateStr;

                const commentsList = document.getElementById('detail-comments-list');
                commentsList.innerHTML = "";
                const comments = data.comments || [];
                document.getElementById('comment-count-label').innerText = `共 ${comments.length} 条评论`;
                comments.forEach(c => {
                    // gorm.Model 的时间字段序列化后默认叫 CreatedAt
                    const dateStr = c.CreatedAt ? c.CreatedAt.split('T')[0] : "刚刚";
                    const avatarPath = `/asset/${c.user.username}/${c.user.avatar}`;

                    commentsList.innerHTML += `
                        <div class="mock-comment">
                            <img src="${avatarPath}" onerror="this.onerror=null; this.src='https://via.placeholder.com/32'">
                            <div class="mock-comment-content" style="flex: 1;">
                                <div class="name" style="color: #666; font-size: 13px; margin-bottom: 4px; display: flex; justify-content: space-between;">
                                    <span>${c.user.username}</span>
                                    <span style="color: #999; font-size: 12px;">${dateStr}</span>
                                </div>
                                <div class="text" style="color: #333; font-size: 14px; line-height: 1.5;">${c.text}</div>
                            </div>
                        </div>
                    `;
                });
            } else {
                alert("获取笔记详情失败");
                closePostDetail();
            }
        } catch (err) {
            console.error(err);
            alert("网络错误");
        }
    }

    function closePostDetail() {
        document.getElementById('post-detail-modal').style.display = 'none';
        // 清空内容，防止下次点开看到上一次残影
        document.getElementById('detail-image').src = "";
        document.getElementById('detail-title').innerText = "加载中...";
        document.getElementById('detail-text').innerText = "加载中...";
    }

    async function toggleLike() {
        if (!currentPostId) return;
        try {
            // 将发往你马上要写的后端接口
            const res = await fetch('/api/post/like', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ post_id: Number(currentPostId) })
            });

            if (res.ok) {
                const data = await res.json();
                // 动态更新UI
                const btnLike = document.getElementById('btn-like');
                const iconLike = document.getElementById('icon-like');
                document.getElementById('count-like').innerText = data.like_count;

                if (data.is_liked) {
                    btnLike.classList.add('liked');
                    iconLike.className = 'fas fa-heart';
                } else {
                    btnLike.classList.remove('liked');
                    iconLike.className = 'far fa-heart';
                }
            } else {
                alert("操作失败，请先登录！");
            }
        } catch (err) { alert("网络请求错误"); }
    }

    // 收藏交互 (逻辑与点赞高度一致)
    async function toggleCollect() {
        if (!currentPostId) return;
        try {
            const res = await fetch('/api/post/collect', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ post_id: Number(currentPostId) })
            });

            if (res.ok) {
                const data = await res.json();
                const btnCollect = document.getElementById('btn-collect');
                const iconCollect = document.getElementById('icon-collect');
                document.getElementById('count-collect').innerText = data.collect_count;

                if (data.is_collected) {
                    btnCollect.classList.add('collected');
                    iconCollect.className = 'fas fa-star';
                } else {
                    btnCollect.classList.remove('collected');
                    iconCollect.className = 'far fa-star';
                }
            } else {
                alert("操作失败，请先登录！");
            }
        } catch (err) { alert("网络请求错误"); }
    }

    async function submitComment() {
        if (!currentPostId) return;
        const input = document.getElementById('comment-input');
        const text = input.value.trim();

        if (!text) return alert("评论内容不能为空！");

        try {
            // 发给后端新增的评论接口
            const res = await fetch('/api/post/comment', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ post_id: Number(currentPostId), text: text })
            });

            if (res.ok) {
                input.value = ""; // 清空输入框
                // 评论成功后，直接重新调用该函数刷新一遍详情页的数据，实现无缝显示新评论
                openPostDetail(currentPostId);
            } else {
                const data = await res.json();
                alert(data.error || "评论失败，请先登录！");
            }
        } catch (err) {
            alert("网络请求错误");
        }
    }
</script>

</body>
</html>