<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ .User.Username }} 的主页 - 小红书</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link href="/static/index.css" rel="stylesheet">
    <link href="/static/profile.css" rel="stylesheet">
</head>
<body>

<aside class="sidebar">
    <div class="logo">小红书</div>
    <nav>
        <a href="/" class="nav-item"><i class="fas fa-compass"></i> 发现</a>
        <a href="/publish" class="nav-item"><i class="fas fa-plus-square"></i> 发布</a>
        <a href="#" class="nav-item"><i class="fas fa-bell"></i> 通知</a>
        <a href="/user/profile/{{.LoggedInUserID}}" class="nav-item active"><i class="fas fa-user"></i> 我</a>
    </nav>

    <div class="more-container">
        <div class="more-menu" id="more-menu">
            <div class="menu-item">关于小红书</div>
            <div class="menu-item">帮助与客服</div>
            <div class="menu-divider"></div>
            <div class="menu-item" onclick="handleLogout()">退出登录</div>
        </div>
        <div class="more-btn" onclick="toggleMoreMenu(event)">
            <i class="fas fa-bars"></i> 更多
        </div>
    </div>
</aside>

<main class="main-container">
    <div class="user-header">
        <img src="/asset/{{.User.Username}}/{{.User.Avatar}}" onerror="this.src='https://via.placeholder.com/150'" class="user-avatar" alt="avatar">

        <div class="user-info">
            <div class="user-name-row">
                <h1 class="user-name">{{ .User.Username }}</h1>
                {{ if .IsOwner }}
                    <button class="btn-edit-profile" onclick="openEditModal()">编辑资料</button>
                {{ else }}
                    <button id="profile-btn-follow" class="btn-follow" onclick="toggleProfileFollow('{{ .User.ID }}')"
                            style="padding: 8px 24px; border-radius: 20px; font-weight: bold; cursor: pointer; border: none; transition: all 0.2s;
                                    {{ if .IsFollowing }}background: #f0f0f0; color: #999;{{ else }}background: var(--primary-red); color: white;{{ end }}">
                        {{ if .IsFollowing }}已关注{{ else }}关注{{ end }}
                    </button>
                {{ end }}
            </div>

            <div class="user-meta">
                <span>小红书号：{{ .User.ID }}</span>
                <span>属地：{{ if .User.Region }}{{ .User.Region }}{{ else }}未知{{ end }}</span>
            </div>

            <div class="user-bio">
                {{ if .User.Signature }}{{ .User.Signature }}{{ else }}这个人很懒，什么都没写{{ end }}
            </div>

            <div class="user-tags">
                {{ if .User.Gender }}<span class="tag">{{.User.Gender}}</span>{{ end }}
                <span class="tag">双子座</span>
            </div>

            <div class="user-stats-row">
                <div class="user-stats">
                    <div class="stat-item"><span class="stat-num" id="stat-following">{{ .FollowingCount }}</span>关注</div>
                    <div class="stat-item"><span class="stat-num" id="stat-follower">{{ .FollowerCount }}</span>粉丝</div>
                    <div class="stat-item"><span class="stat-num">{{ .TotalFavorited }}</span>获赞与收藏</div>
                </div>
            </div>
        </div>
    </div>

    <div class="tabs">
        <div class="tab-item active">笔记</div>
        <div class="tab-item">收藏</div>
        <div class="tab-item">点赞</div>
    </div>

    {{ if .Posts }}
        <div class="posts-grid">
            {{ range .Posts }}
                <div class="post-card" onclick="openPostDetail('{{ .ID }}')">
                    <img src="/asset/{{ $.User.Username }}/Posts/{{ .ID }}/{{ .CoverImage }}" class="cover-img"
                         alt="{{ .Title }}">
                    <div class="card-footer">
                        <div class="post-title">{{ .Title }}</div>
                        <div class="post-meta">
                            <div class="user-mini">
                                <img src="/asset/{{ $.User.Username }}/{{ $.User.Avatar }}" class="avatar-mini">
                                <span>{{ $.User.Username }}</span>
                            </div>

                            <div>
                                <i class="{{ if .IsLiked }}fas fa-heart{{ else }}far fa-heart{{ end }}"
                                   {{ if .IsLiked }}style="color: var(--primary-red);"{{ end }}></i>
                                <span>{{ .LikeCount }}</span>
                            </div>

                        </div>
                    </div>
                </div>
            {{ end }}
        </div>
    {{ else }}
        <div class="empty-state">
            还没有发布过笔记哦 ~
        </div>
    {{ end }}
</main>

<div id="edit-modal" class="modal-overlay" style="display: none;">
    <div class="edit-modal-content">
        <span class="close-btn" onclick="closeEditModal()"><i class="fas fa-times"></i></span>
        <div class="edit-modal-header">编辑个人资料</div>

        <div class="avatar-upload-box">
            <label for="edit-avatar" class="avatar-preview-wrap">
                <img id="avatar-preview" src="/asset/{{.User.Username}}/{{.User.Avatar}}"
                     onerror="this.src='https://via.placeholder.com/150'" alt="avatar">
                <div class="overlay"><i class="fas fa-camera"></i></div>
            </label>
            <input type="file" id="edit-avatar" accept="image/*" style="display: none;" onchange="previewImage(event)">
        </div>

        <div class="form-group">
            <label>性别</label>
            <select id="edit-gender">
                <option value="男" {{if eq .User.Gender "男"}}selected{{end}}>男</option>
                <option value="女" {{if eq .User.Gender "女"}}selected{{end}}>女</option>
                <option value="保密" {{if eq .User.Gender "保密"}}selected{{end}}>保密</option>
            </select>
        </div>

        <div class="form-group">
            <label>生日</label>
            <input type="date" id="edit-birthday"
                   value="{{ if .User.Birthday }}{{ .User.Birthday.Format "2006-01-02" }}{{ end }}">
        </div>

        <div class="form-group">
            <label>地区</label>
            <input type="text" id="edit-region" value="{{.User.Region}}" placeholder="例如：中国, 上海">
        </div>

        <div class="form-group">
            <label>个性签名</label>
            <input type="text" id="edit-signature" value="{{.User.Signature}}" placeholder="介绍一下自己吧...">
        </div>

        <button class="submit-btn" onclick="submitEdit()">保存资料</button>
    </div>
</div>

<div id="post-detail-modal" class="post-detail-overlay" style="display: none;">
    <div class="post-detail-box">
        <div class="post-detail-left">
            <div class="close-detail-btn" onclick="closePostDetail()"><i class="fas fa-times"></i></div>
            <img id="detail-image" src="" alt="笔记封面">
        </div>

        <div class="post-detail-right">
            <div class="detail-header">
                <div class="detail-author">
                    <img id="detail-avatar" src="/asset/{{ .User.Username }}/{{ .User.Avatar }}" onerror="this.src='https://via.placeholder.com/40'">
                    <span id="detail-username">加载中...</span>
                </div>
                <button id="modal-btn-follow" class="btn-follow" onclick="toggleModalFollow()" style="display: none; transition: all 0.2s;">关注</button>
            </div>

            <div class="detail-scroll">
                <div id="detail-title" class="detail-title">加载中...</div>
                <div id="detail-text" class="detail-text">加载中...</div>
                <div id="detail-time" class="detail-time">发布时间</div>

                <hr style="border: 0; border-top: 1px solid #f0f0f0; margin: 20px 0;">

                <div id="comment-count-label" class="comment-count">共 0 条评论</div>
                <div id="detail-comments-list" style="padding-bottom: 20px;"></div>
            </div>

            <div class="detail-footer">
                <div style="flex: 1; display: flex; align-items: center; background: #f5f5f5; border-radius: 24px; padding-right: 15px;">
                    <input type="text" id="comment-input" class="comment-input" placeholder="说点什么..." style="flex: 1; background: transparent; padding-right: 5px;">
                    <span onclick="submitComment()" style="color: var(--primary-red); font-weight: bold; cursor: pointer; white-space: nowrap; font-size: 14px;">发送</span>
                </div>
                <div class="interaction-icons" style="margin-left: 15px;">
                    <div class="action-btn" id="btn-like" onclick="toggleLike()">
                        <i id="icon-like" class="far fa-heart"></i>
                        <span id="count-like">0</span>
                    </div>

                    <div class="action-btn" id="btn-collect" onclick="toggleCollect()">
                        <i id="icon-collect" class="far fa-star"></i>
                        <span id="count-collect">0</span>
                    </div>

                    <div class="action-btn">
                        <i class="fas fa-share"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    let currentPostId = null
    let currentReplyParentId = 0;
    let currentReplyToName = "";
    let currentPostAuthorId = 0;

    function openEditModal() {
        document.getElementById('edit-modal').style.display = 'flex';
    }

    function closeEditModal() {
        document.getElementById('edit-modal').style.display = 'none';
    }

    function previewImage(event) {
        const file = event.target.files[0];
        if (file) {
            document.getElementById('avatar-preview').src = URL.createObjectURL(file);
        }
    }

    async function submitEdit() {
        const formData = new FormData();
        formData.append("gender", document.getElementById('edit-gender').value);
        formData.append("region", document.getElementById('edit-region').value);
        formData.append("signature", document.getElementById('edit-signature').value);
        formData.append("birthday", document.getElementById('edit-birthday').value);

        const avatarFile = document.getElementById('edit-avatar').files[0];
        if (avatarFile) {
            formData.append("avatar", avatarFile);
        }

        try {
            const res = await fetch('/api/user/update', {method: 'POST', body: formData});
            if (res.ok) {
                window.location.reload();
            } else {
                alert("更新失败");
            }
        } catch (err) {
            alert("网络错误");
        }
    }

    function toggleMoreMenu(e) {
        e.stopPropagation(); // 阻止点击事件冒泡，防止触发下面的全局关闭
        document.getElementById('more-menu').classList.toggle('show');
    }

    // 监听全局点击事件，点击空白处自动关闭菜单
    document.addEventListener('click', function(e) {
        const menu = document.getElementById('more-menu');
        if (menu && menu.classList.contains('show')) {
            menu.classList.remove('show');
        }
    });

    // 处理退出登录
    async function handleLogout() {
        try {
            const res = await fetch('/api/logout', { method: 'POST' });
            if (res.ok) {
                // 登出成功后，强制跳转回首页，首页检测不到 Cookie 会自动弹出登录框
                window.location.href = "/";
            } else {
                alert("退出失败，请重试");
            }
        } catch (err) {
            alert("网络请求错误");
        }
    }

    async function openPostDetail(postId) {
        document.getElementById('post-detail-modal').style.display = 'flex';

        try {
            const res = await fetch(`/api/post/detail?id=${postId}`);
            if (res.ok) {
                const data = await res.json(); // 解析返回的JSON
                currentPostId = postId

                const btnFollow = document.getElementById('modal-btn-follow');
                currentPostAuthorId = data.post.user_id; // 获取作者ID

                // 如果自己看自己的帖子，不显示关注按钮
                // 注意这里需要你把 loggedInUserID 传给前端，或者后端判断如果没登录就是 ""
                const myUserId = '{{ .LoggedInUserID }}';
                if (String(currentPostAuthorId) === myUserId) {
                    btnFollow.style.display = 'none';
                } else {
                    btnFollow.style.display = 'block';
                    if (data.is_following) {
                        btnFollow.innerText = "已关注";
                        btnFollow.style.background = "#f0f0f0";
                        btnFollow.style.color = "#999";
                    } else {
                        btnFollow.innerText = "关注";
                        btnFollow.style.background = "var(--primary-red)";
                        btnFollow.style.color = "white";
                    }
                }

                document.getElementById('detail-image').src = `/asset/${data.user.username}/Posts/${data.post.ID}/${data.post.cover_image}`;
                document.getElementById('detail-avatar').src = `/asset/${data.user.username}/${data.user.avatar}`;
                document.getElementById('detail-username').innerText = data.user.username;
                document.getElementById('detail-title').innerText = data.post.title;
                document.getElementById('detail-text').innerText = data.post.text;
                document.getElementById('count-like').innerText = data.like_count || 0;
                document.getElementById('count-collect').innerText = data.collect_count || 0;

                const btnLike = document.getElementById('btn-like');
                const iconLike = document.getElementById('icon-like');
                if (data.is_liked) {
                    btnLike.classList.add('liked');
                    iconLike.className = 'fas fa-heart';
                } else {
                    btnLike.classList.remove('liked');
                    iconLike.className = 'far fa-heart';
                }

                // 根据是否已收藏，切换 class
                const btnCollect = document.getElementById('btn-collect');
                const iconCollect = document.getElementById('icon-collect');
                if (data.is_collected) {
                    btnCollect.classList.add('collected');
                    iconCollect.className = 'fas fa-star';
                } else {
                    btnCollect.classList.remove('collected');
                    iconCollect.className = 'far fa-star';
                }

                // 格式化时间 (截取 YYYY-MM-DD)
                const dateStr = data.post.public_date ? data.post.public_date.split('T')[0] : "未知时间";
                document.getElementById('detail-time').innerText = dateStr;

                // === 替换开始：动态渲染楼中楼评论 ===
                const commentsList = document.getElementById('detail-comments-list');
                commentsList.innerHTML = "";
                const comments = data.comments || [];
                document.getElementById('comment-count-label').innerText = `共 ${comments.length} 条评论`;

                currentPostAuthorId = data.post.user_id; // 获取文章作者ID

                // 辅助函数：渲染单条评论的 HTML
                function renderCommentHTML(c, isSub, threadId) {
                    const dateStr = c.CreatedAt ? c.CreatedAt.split('T')[0] : "刚刚";
                    const avatarPath = `/asset/${c.user.username}/${c.user.avatar}`;
                    const likeIconClass = c.is_liked ? 'fas fa-heart' : 'far fa-heart';
                    const likeColor = c.is_liked ? 'color: var(--primary-red);' : 'color: #999;';

                    // 💡 如果是回复的回复，加上高亮的 @ 前缀
                    let textHtml = c.text;
                    if (isSub && c.reply_to) {
                        textHtml = `<span>回复 <span style="color: #5c7c9c;">@${c.reply_to}</span>: </span>${c.text}`;
                    }

                    // 判断是否是楼主（作者）
                    const authorTag = c.user_id === currentPostAuthorId ?
                        '<span style="background:#f0f0f0; color:#999; font-size:10px; padding:2px 6px; border-radius:10px; margin-left:6px;">作者</span>' : '';

                    // threadId 是顶级评论的 ID
                    const clickParentId = isSub ? threadId : c.ID;

                    return `
                        <div class="mock-comment" style="margin-bottom: ${isSub ? '15px' : '20px'};">
                            <img src="${avatarPath}" style="width: ${isSub ? '24px' : '32px'}; height: ${isSub ? '24px' : '32px'}; border-radius: 50%;" onerror="this.onerror=null; this.src='https://via.placeholder.com/32'">
                            <div class="mock-comment-content" style="flex: 1;">
                                <div class="name" style="color: #666; font-size: 13px; margin-bottom: 4px; display: flex; justify-content: space-between;">
                                    <span>${c.user.username}${authorTag}</span>
                                    <span style="color: #999; font-size: 12px;">${dateStr}</span>
                                </div>
                                <div class="text" style="color: #333; font-size: 14px; line-height: 1.5;">${textHtml}</div>

                                <div style="display: flex; align-items: center; gap: 20px; margin-top: 8px; font-size: 12px; color: #999;">
                                    <div style="cursor: pointer; display: flex; align-items: center; gap: 4px;" onclick="toggleCommentLike(${c.ID})">
                                        <i id="comment-like-icon-${c.ID}" class="${likeIconClass}" style="${likeColor} font-size: 13px; transition: transform 0.2s;"></i>
                                        <span id="comment-like-count-${c.ID}">${c.like_count || 0}</span>
                                    </div>
                                    <div style="cursor: pointer; font-weight: 500;" onclick="prepareReply(${clickParentId}, '${c.user.username}', ${isSub})">回复</div>
                                </div>
                            </div>
                        </div>
                    `;
                }

                // 💡 分组算法：挑出所有一级评论
                const topComments = comments.filter(c => !c.parent_id || c.parent_id === 0);
                topComments.forEach(tc => {
                    let html = renderCommentHTML(tc, false, tc.ID);

                    // 挑出属于这个一级评论的所有子评论（楼中楼）
                    const subComments = comments.filter(c => c.parent_id === tc.ID);
                    if (subComments.length > 0) {
                        html += `<div style="margin-left: 42px; margin-bottom: 20px; padding: 10px 15px; background: #f9f9f9; border-radius: 8px;">`;
                        // 这里反转一下数组，让旧回复在上，新回复在下，更符合阅读习惯
                        subComments.reverse().forEach(sc => {
                            html += renderCommentHTML(sc, true, tc.ID);
                        });
                        html += `</div>`;
                    }
                    commentsList.innerHTML += html;
                });
                // === 替换结束 ===
            } else {
                alert("获取笔记详情失败");
                closePostDetail();
            }
        } catch (err) {
            console.error(err);
            alert("网络错误");
        }
    }

    function closePostDetail() {
        document.getElementById('post-detail-modal').style.display = 'none';
        // 清空内容，防止下次点开看到上一次残影
        document.getElementById('detail-image').src = "";
        document.getElementById('detail-title').innerText = "加载中...";
        document.getElementById('detail-text').innerText = "加载中...";
    }

    async function toggleLike() {
        if (!currentPostId) return;
        try {
            // 将发往你马上要写的后端接口
            const res = await fetch('/api/post/like', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ post_id: Number(currentPostId) })
            });

            if (res.ok) {
                const data = await res.json();
                // 动态更新UI
                const btnLike = document.getElementById('btn-like');
                const iconLike = document.getElementById('icon-like');
                document.getElementById('count-like').innerText = data.like_count;

                if (data.is_liked) {
                    btnLike.classList.add('liked');
                    iconLike.className = 'fas fa-heart';
                } else {
                    btnLike.classList.remove('liked');
                    iconLike.className = 'far fa-heart';
                }
            } else {
                alert("操作失败，请先登录！");
            }
        } catch (err) { alert("网络请求错误"); }
    }

    // 收藏交互 (逻辑与点赞高度一致)
    async function toggleCollect() {
        if (!currentPostId) return;
        try {
            const res = await fetch('/api/post/collect', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ post_id: Number(currentPostId) })
            });

            if (res.ok) {
                const data = await res.json();
                const btnCollect = document.getElementById('btn-collect');
                const iconCollect = document.getElementById('icon-collect');
                document.getElementById('count-collect').innerText = data.collect_count;

                if (data.is_collected) {
                    btnCollect.classList.add('collected');
                    iconCollect.className = 'fas fa-star';
                } else {
                    btnCollect.classList.remove('collected');
                    iconCollect.className = 'far fa-star';
                }
            } else {
                alert("操作失败，请先登录！");
            }
        } catch (err) { alert("网络请求错误"); }
    }

    window.prepareReply = function(parentId, targetName, isSub) {
        currentReplyParentId = parentId;
        // 如果回复的是二级评论，我们才加上 @ 他的名字
        currentReplyToName = isSub ? targetName : "";

        const input = document.getElementById('comment-input');
        input.placeholder = `回复 @${targetName} :`;
        input.focus();
    };

    // 💡 升级：提交评论时带上楼中楼关系
    async function submitComment() {
        if (!currentPostId) return;
        const input = document.getElementById('comment-input');
        const text = input.value.trim();

        if (!text) return alert("评论内容不能为空！");

        try {
            const res = await fetch('/api/post/comment', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    post_id: Number(currentPostId),
                    text: text,
                    parent_id: currentReplyParentId,   // 传给后端：归属哪个大楼
                    reply_to: currentReplyToName       // 传给后端：@了谁
                })
            });

            if (res.ok) {
                input.value = "";
                input.placeholder = "说点什么..."; // 恢复默认占位符
                currentReplyParentId = 0;          // 清除回复状态
                currentReplyToName = "";

                openPostDetail(currentPostId);     // 刷新评论区
            } else {
                const data = await res.json();
                alert(data.error || "评论失败，请先登录！");
            }
        } catch (err) {
            alert("网络请求错误");
        }
    }

    async function toggleCommentLike(commentId) {
        try {
            // 发给你要写的后端新接口
            const res = await fetch('/api/comment/like', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ comment_id: Number(commentId) })
            });

            if (res.ok) {
                const data = await res.json();

                // 获取对应评论的 DOM 元素进行局部刷新 (这样点赞不用重新加载整个列表)
                const icon = document.getElementById(`comment-like-icon-${commentId}`);
                const countSpan = document.getElementById(`comment-like-count-${commentId}`);

                countSpan.innerText = data.like_count;
                if (data.is_liked) {
                    icon.className = 'fas fa-heart';
                    icon.style.color = 'var(--primary-red)';
                } else {
                    icon.className = 'far fa-heart';
                    icon.style.color = '#999';
                }
            } else {
                alert("操作失败，请先登录！");
            }
        } catch (err) {
            alert("网络请求错误");
        }
    }

    async function toggleModalFollow() {
        if (!currentPostAuthorId) return;
        await sendFollowRequest(currentPostAuthorId, 'modal');
    }

    // 💡 处理个人主页大按钮的关注点击
    async function toggleProfileFollow(targetId) {
        await sendFollowRequest(targetId, 'profile');
    }

    // 统一发送关注请求的函数
    async function sendFollowRequest(targetId, source) {
        try {
            const res = await fetch('/api/user/follow', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ target_id: Number(targetId) })
            });

            if (res.ok) {
                const data = await res.json();

                // 如果是在详情弹窗里点的
                if (source === 'modal') {
                    const btn = document.getElementById('modal-btn-follow');
                    if (data.is_following) {
                        btn.innerText = "已关注";
                        btn.style.background = "#f0f0f0";
                        btn.style.color = "#999";
                    } else {
                        btn.innerText = "关注";
                        btn.style.background = "var(--primary-red)";
                        btn.style.color = "white";
                    }
                }
                // 如果是在个人主页点的
                else if (source === 'profile') {
                    // 刷新当前页面让各种统计数字重新计算
                    window.location.reload();
                }
            } else {
                alert("请先登录！");
            }
        } catch (err) { alert("网络错误"); }
    }
</script>

</body>
</html>